{
  "name": "paositra-management-suite",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node scripts/run-postgres-integration.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm run dev -w @paositra/api",
    "dev:treasury": "npm run dev -w @paositra/treasury-web",
    "dev:operations": "npm run dev -w @paositra/operations-web",
    "db:migrate": "node scripts/migrate.mjs",
    "db:bootstrap-admin": "npm run bootstrap-admin -w @paositra/api",
    "openapi:generate": "npm run build -w @paositra/api && node apps/api/dist/scripts/generate-openapi.js",
    "openapi:check": "node scripts/check-openapi.mjs",
    "db:seed": "node scripts/seed-demo.mjs",
    "db:seed:paoma": "node scripts/seed-paoma-complements.mjs",
    "demo:reset-users": "node scripts/demo-reset-users.mjs"
  },
  "dependencies": {
    "pg": "8.16.0"
  },
  "overrides": {
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": {
      ".": "11.1.26",
      "multer": "2.2.0"
    },
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "tsx": "4.22.4",
    "typescript": "5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19"
  }
}
