NODE_ENV=development
PORT=3000
POSTGRES_ADMIN_PASSWORD=replace-with-a-strong-local-admin-password
PAOSITRA_OWNER_PASSWORD=replace-with-a-strong-migration-password
PAOSITRA_APP_PASSWORD=replace-with-a-strong-application-password
MIGRATION_DATABASE_URL=postgresql://paositra_owner:replace-with-a-strong-migration-password@localhost:55432/paositra
DATABASE_URL=postgresql://paositra_app:replace-with-a-strong-application-password@localhost:55432/paositra
DATABASE_SSL=false
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_TTL_SECONDS=900
SESSION_IDLE_TIMEOUT_SECONDS=900
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081
VITE_DEMO_MODE=false
MAX_UPLOAD_BYTES=268435456
UPLOAD_ROOT=./uploads
CONTROLLED_BOOTSTRAP_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
BOOTSTRAP_PERMISSION_CODES=
